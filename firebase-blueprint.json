{
  "entities": {
    "Company": {
      "title": "Company",
      "description": "A company managed in the system",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "nit": { "type": "string" },
        "riskLevel": { "type": "number", "enum": [1, 2, 3, 4, 5] },
        "workerCount": { "type": "number" },
        "standardsCount": { "type": "number" },
        "completedStandards": { "type": "array", "items": { "type": "string" } },
        "compliancePercentage": { "type": "number" }
      },
      "required": ["id", "name", "nit", "riskLevel", "workerCount", "standardsCount", "completedStandards", "compliancePercentage"]
    },
    "Worker": {
      "title": "Worker",
      "description": "A worker associated with a company",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "companyId": { "type": "string" },
        "employmentStatus": { "type": "string", "enum": ["Activo", "Retirado"] },
        "riskLevel": { "type": "string", "enum": ["low", "medium", "high"] },
        "location": { "type": "string" },
        "lastCheck": { "type": "string" },
        "status": {
          "type": "object",
          "properties": {
            "helmet": { "type": "boolean" },
            "vest": { "type": "boolean" },
            "gloves": { "type": "boolean" },
            "glasses": { "type": "boolean" },
            "boots": { "type": "boolean" }
          }
        },
        "vitals": {
          "type": "object",
          "properties": {
            "heartRate": { "type": "number" },
            "temp": { "type": "number" }
          }
        },
        "medicalExams": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": { "type": "string" },
              "date": { "type": "string" },
              "expiryDate": { "type": "string" },
              "result": { "type": "string" }
            }
          }
        },
        "vaccinations": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": { "type": "string" },
              "date": { "type": "string" },
              "dose": { "type": "string" },
              "nextDose": { "type": "string" }
            }
          }
        }
      },
      "required": ["id", "name", "role", "companyId", "employmentStatus", "riskLevel", "location", "lastCheck", "status", "vitals", "medicalExams", "vaccinations"]
    },
    "Alert": {
      "title": "Alert",
      "description": "A safety alert generated by the system",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "timestamp": { "type": "string" },
        "workerId": { "type": "string" },
        "workerName": { "type": "string" },
        "type": { "type": "string" },
        "severity": { "type": "string", "enum": ["critical", "warning", "info"] },
        "message": { "type": "string" }
      },
      "required": ["id", "timestamp", "type", "severity", "message"]
    }
  },
  "firestore": {
    "/companies/{companyId}": {
      "schema": "Company",
      "description": "Collection of companies"
    },
    "/workers/{workerId}": {
      "schema": "Worker",
      "description": "Collection of workers"
    },
    "/alerts/{alertId}": {
      "schema": "Alert",
      "description": "Collection of alerts"
    }
  }
}
